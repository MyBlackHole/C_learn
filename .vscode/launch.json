{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Debug", //名称
            "type": "cppdbg", //调试类型，除使用msvc进行调试外，均为该类型
            "request": "launch",
            "program": "${workspaceFolder}/build/${fileBasenameNoExtension}", //指定C/C++程序位置
            // "program": "${workspaceFolder}/build/test", //指定C/C++程序位置
            "args": [], //指定运行参数
            "stopAtEntry": false,
            // "targetArchitecture": "rsicv",
            "cwd": "${workspaceFolder}/build", //指定工作目录
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb", //指定使用gdb调试
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "compile", //在调试前会先调用这个task编译构建程序
            "sourceFileMap":{  // 源文件映射
                ".": "/usr/src/glibc"
            },
            "miDebuggerPath": "/usr/bin/gdb" // 指定调试路径
        }
    ]
}