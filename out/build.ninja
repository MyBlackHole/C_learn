build execlp_test: phony obj/unistd_learn/execlp_test
build fcntl_test: phony obj/fcntl_learn/fcntl_test
build fgets_test: phony obj/stdio_learn/fgets_test
build fopen_test: phony obj/stdio_learn/fopen_test
build fork_test: phony obj/unistd_learn/fork_test
build futimens_test: phony obj/stat_learn/futimens_test
build getc_test: phony obj/stdio_learn/getc_test
build getcwd_test: phony obj/unistd_learn/getcwd_test
