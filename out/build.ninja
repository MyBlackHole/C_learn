ninja_required_version = 1.7.2

rule gn
  command = ../../../../../../../usr/bin/gn --root=./.. -q gen .
  description = Regenerating ninja files

build build.ninja: gn
  generator = 1
  depfile = build.ninja.d

subninja toolchain.ninja

build default: phony obj/default.stamp
build errno_learn: phony obj/errno_learn/errno_learn
build hello_word: phony obj/hello_word/hello_word
build 2: phony obj/grammar/2
build access_test: phony obj/unistd_learn/access_test
build atexit_test: phony obj/stdlib_learn/atexit_test
build chdir_test: phony obj/unistd_learn/chdir_test
build chmod_test: phony obj/stat_learn/chmod_test
build creat_test: phony obj/fcntl_learn/creat_test
