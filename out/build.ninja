build longjmp_test: phony obj/setjmp_learn/longjmp_test
build lseek1_test: phony obj/unistd_learn/lseek1_test
build lseek_test: phony obj/unistd_learn/lseek_test
build memset_test: phony obj/string_learn/memset_test
build mkstemp_test: phony obj/stdlib_learn/mkstemp_test
build pipe1: phony obj/pipe_learn/pipe1
build read_test: phony obj/unistd_learn/read_test
build readdir_test: phony obj/dirent_learn/readdir_test
build select_test: phony obj/sys_select_learn/select_test
build setjmp_test: phony obj/setjmp_learn/setjmp_test
