defines =
include_dirs = -I../include
cflags = -g
cflags_c =
target_out_dir = obj/stdlib_learn
target_output_name = atexit_test

build obj/stdlib_learn/atexit_test.atexit_test.o: cc ../stdlib_learn/atexit_test.c

build obj/stdlib_learn/atexit_test: link obj/stdlib_learn/atexit_test.atexit_test.o obj/lib/libc.a
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
