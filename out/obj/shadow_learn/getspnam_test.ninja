defines =
include_dirs = -I../include
cflags = -g
cflags_c =
target_out_dir = obj/shadow_learn
target_output_name = getspnam_test

build obj/shadow_learn/getspnam_test.getspnam_test.o: cc ../shadow_learn/getspnam_test.c

build obj/shadow_learn/getspnam_test: link obj/shadow_learn/getspnam_test.getspnam_test.o obj/lib/libc.a
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
