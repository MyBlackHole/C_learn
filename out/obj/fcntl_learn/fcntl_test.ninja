defines =
include_dirs = -I../include
cflags = -g
cflags_c =
target_out_dir = obj/fcntl_learn
target_output_name = fcntl_test

build obj/fcntl_learn/fcntl_test.fcntl_test.o: cc ../fcntl_learn/fcntl_test.c

build obj/fcntl_learn/fcntl_test: link obj/fcntl_learn/fcntl_test.fcntl_test.o obj/lib/libc.a
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
