defines =
include_dirs = -I../include
cflags =
cflags_c =
target_out_dir = obj/lib
target_output_name = libc

build obj/lib/libc.prexit.o: cc ../lib/prexit.c
build obj/lib/libc.error.o: cc ../lib/error.c

build obj/lib/libc.a: alink obj/lib/libc.prexit.o obj/lib/libc.error.o
  arflags =
  output_extension = .a
  output_dir = 
