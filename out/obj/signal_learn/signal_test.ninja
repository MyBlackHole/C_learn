defines =
include_dirs = -I../include
cflags = -g
cflags_c =
target_out_dir = obj/signal_learn
target_output_name = signal_test

build obj/signal_learn/signal_test.signal_test.o: cc ../signal_learn/signal_test.c

build obj/signal_learn/signal_test: link obj/signal_learn/signal_test.signal_test.o obj/lib/libc.a
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
