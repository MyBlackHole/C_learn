build obj/string_learn/memset_test.memset_test.o: cc ../string_learn/memset_test.c

build obj/string_learn/memset_test: link obj/string_learn/memset_test.memset_test.o obj/lib/libc.a
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
