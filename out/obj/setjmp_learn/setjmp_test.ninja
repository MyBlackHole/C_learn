defines =
include_dirs = -I../include
cflags = -g
cflags_c =
target_out_dir = obj/setjmp_learn
target_output_name = setjmp_test

build obj/setjmp_learn/setjmp_test.setjmp_test.o: cc ../setjmp_learn/setjmp_test.c

build obj/setjmp_learn/setjmp_test: link obj/setjmp_learn/setjmp_test.setjmp_test.o
  ldflags =
  libs =
  frameworks =
  output_extension = 
  output_dir = .
